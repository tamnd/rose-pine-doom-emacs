;;; doom-rose-pine-common.el --- Shared spec for Rosé Pine themes -*- lexical-binding: t; no-byte-compile: t; -*-
;;
;; Author: tamnd
;; Keywords: faces, custom themes
;; Homepage: https://github.com/tamnd/rose-pine-doom-emacs
;; Package-Requires: ((emacs "27.1") (doom-themes "2.2.1"))
;;
;;; Commentary:
;;
;; Shared defcustoms and face spec for the three Rosé Pine variants:
;; `doom-rose-pine', `doom-rose-pine-moon', `doom-rose-pine-dawn'.
;;
;; The variants only differ in their palette.  Every face override is
;; written against the palette role names (rose, gold, foam, pine,
;; iris, love, text, subtle, muted, base, surface, overlay,
;; highlight-low, highlight-med, highlight-high) so a single face spec
;; works for all three.
;;
;;; Code:

(require 'doom-themes)

(defgroup doom-rose-pine nil
  "Options shared by the Rosé Pine theme variants."
  :group 'doom-themes)

(defcustom doom-rose-pine-brighter-modeline nil
  "If non-nil, use a more vivid mode-line background.
Applies to all three Rosé Pine variants."
  :group 'doom-rose-pine
  :type 'boolean)

(defcustom doom-rose-pine-brighter-comments nil
  "If non-nil, draw comments with a subtle tinted background."
  :group 'doom-rose-pine
  :type 'boolean)

(defcustom doom-rose-pine-padded-modeline doom-themes-padded-modeline
  "If non-nil, add padding to the mode-line.
Either a boolean (4-pixel default) or an integer pixel width."
  :group 'doom-rose-pine
  :type '(choice integer boolean))

;; Backwards-compatible aliases for the per-variant custom names used
;; by the original donniebreve port.  Setting any of these continues
;; to work — they all forward to the unified options above.
(define-obsolete-variable-alias 'doom-rose-pine-moon-brighter-modeline
  'doom-rose-pine-brighter-modeline "1.0.0")
(define-obsolete-variable-alias 'doom-rose-pine-moon-brighter-comments
  'doom-rose-pine-brighter-comments "1.0.0")
(define-obsolete-variable-alias 'doom-rose-pine-moon-padded-modeline
  'doom-rose-pine-padded-modeline "1.0.0")
(define-obsolete-variable-alias 'doom-rose-pine-dawn-brighter-modeline
  'doom-rose-pine-brighter-modeline "1.0.0")
(define-obsolete-variable-alias 'doom-rose-pine-dawn-brighter-comments
  'doom-rose-pine-brighter-comments "1.0.0")
(define-obsolete-variable-alias 'doom-rose-pine-dawn-padded-modeline
  'doom-rose-pine-padded-modeline "1.0.0")

(defconst doom-rose-pine--face-spec
  '(;; --- core editor ---
    ((font-lock-comment-face &override)
     :slant 'italic
     :background (if doom-rose-pine-brighter-comments (doom-blend foam base 0.07)))
    ((font-lock-doc-face &override) :slant 'italic)
    ((font-lock-type-face &override) :foreground type :slant 'italic)
    ((font-lock-builtin-face &override) :foreground builtin :slant 'italic)
    ((font-lock-function-name-face &override) :foreground functions)
    ((font-lock-variable-name-face &override) :foreground variables)
    ((font-lock-keyword-face &override) :foreground keywords :weight 'bold)
    ((font-lock-constant-face &override) :foreground constants :weight 'bold)
    ((font-lock-number-face &override) :foreground numbers)
    ((font-lock-string-face &override) :foreground strings)
    ((font-lock-operator-face &override) :foreground operators)
    ((font-lock-punctuation-face &override) :foreground subtle)
    ((font-lock-bracket-face &override) :foreground subtle)
    ((font-lock-delimiter-face &override) :foreground subtle)
    ((font-lock-property-name-face &override) :foreground text)
    ((font-lock-property-use-face &override) :foreground text)
    ((font-lock-preprocessor-face &override) :foreground iris)
    ((font-lock-warning-face &override) :foreground gold :weight 'bold)

    (cursor :background highlight)
    (hl-line :background highlight-low)
    ((line-number &override) :foreground muted)
    ((line-number-current-line &override) :foreground rose :weight 'bold)
    (fringe :foreground muted :background bg)
    (vertical-border :foreground overlay :background bg)
    (link :foreground foam :underline t)
    (highlight :foreground base :background rose)
    (lazy-highlight :background highlight-med :foreground text)
    (isearch :background gold :foreground base :weight 'bold)
    (isearch-fail :background love :foreground base)
    (match :foreground gold :weight 'bold)
    (success :foreground foam)
    (warning :foreground gold)
    (error   :foreground love)
    (escape-glyph :foreground iris)
    (homoglyph    :foreground iris)
    ((show-paren-match &override)
     :foreground rose :background highlight-high :weight 'bold)
    ((show-paren-mismatch &override)
     :foreground base :background love :weight 'bold)
    (trailing-whitespace :background love)
    ((whitespace-tab &override) :foreground highlight-high :background nil)
    ((whitespace-space &override) :foreground highlight-high :background nil)
    ((whitespace-newline &override) :foreground highlight-high :background nil)
    ((whitespace-trailing &override) :foreground love :background nil)
    (header-line :background surface :foreground subtle)
    (mode-line
     :background modeline-bg :foreground modeline-fg
     :box (if modeline-pad `(:line-width ,modeline-pad :color ,modeline-bg)))
    (mode-line-inactive
     :background modeline-bg-inactive :foreground modeline-fg-inactive
     :box (if modeline-pad `(:line-width ,modeline-pad :color ,modeline-bg-inactive)))
    (mode-line-emphasis :foreground (if doom-rose-pine-brighter-modeline text subtle))
    (mode-line-highlight :foreground rose :weight 'bold)
    (mode-line-buffer-id :foreground text :weight 'bold)
    ((minibuffer-prompt &override) :foreground iris :weight 'bold)

    ;; --- tree-sitter / treesit-font-lock ---
    (tree-sitter-hl-face:attribute       :inherit 'font-lock-constant-face)
    (tree-sitter-hl-face:constant        :foreground constants :weight 'bold)
    (tree-sitter-hl-face:constant.builtin :foreground gold :weight 'bold)
    (tree-sitter-hl-face:number          :foreground numbers)
    (tree-sitter-hl-face:comment         :inherit 'font-lock-comment-face)
    (tree-sitter-hl-face:doc             :inherit 'font-lock-doc-face)
    (tree-sitter-hl-face:string          :foreground strings)
    (tree-sitter-hl-face:string.special  :foreground rose)
    (tree-sitter-hl-face:escape          :foreground iris)
    (tree-sitter-hl-face:type            :foreground type :slant 'italic)
    (tree-sitter-hl-face:type.parameter  :foreground iris :slant 'italic)
    (tree-sitter-hl-face:type.argument   :foreground iris)
    (tree-sitter-hl-face:type.builtin    :foreground love :slant 'italic)
    (tree-sitter-hl-face:type.super      :foreground foam :slant 'italic)
    (tree-sitter-hl-face:constructor     :foreground rose)
    (tree-sitter-hl-face:variable        :foreground variables)
    (tree-sitter-hl-face:variable.parameter :foreground iris)
    (tree-sitter-hl-face:variable.builtin :foreground love :slant 'italic)
    (tree-sitter-hl-face:variable.special :foreground rose)
    (tree-sitter-hl-face:property        :foreground text)
    (tree-sitter-hl-face:property.definition :foreground text :weight 'bold)
    (tree-sitter-hl-face:function        :foreground functions)
    (tree-sitter-hl-face:function.call   :foreground functions)
    (tree-sitter-hl-face:function.builtin :foreground love :slant 'italic)
    (tree-sitter-hl-face:function.special :foreground iris)
    (tree-sitter-hl-face:function.macro  :foreground iris)
    (tree-sitter-hl-face:method          :foreground methods)
    (tree-sitter-hl-face:method.call     :foreground methods)
    (tree-sitter-hl-face:keyword         :foreground keywords :weight 'bold)
    (tree-sitter-hl-face:operator        :foreground operators)
    (tree-sitter-hl-face:punctuation     :foreground subtle)
    (tree-sitter-hl-face:punctuation.bracket :foreground subtle)
    (tree-sitter-hl-face:punctuation.delimiter :foreground subtle)
    (tree-sitter-hl-face:punctuation.special :foreground iris)
    (tree-sitter-hl-face:tag             :foreground foam)
    (tree-sitter-hl-face:label           :foreground iris)
    (tree-sitter-hl-face:embedded        :foreground iris)

    ;; --- eglot / lsp-mode ---
    (eglot-highlight-symbol-face :background highlight-med :weight 'bold)
    (eglot-mode-line :foreground rose :weight 'bold)
    (eglot-diagnostic-tag-unnecessary-face :underline `(:style wave :color ,muted))
    (eglot-diagnostic-tag-deprecated-face  :strike-through t :foreground muted)
    (eglot-inlay-hint-face                 :foreground muted :background nil)
    (eglot-parameter-hint-face             :foreground iris  :background nil :slant 'italic)
    (eglot-type-hint-face                  :foreground foam  :background nil :slant 'italic)

    (lsp-face-highlight-read    :background highlight-med :weight 'bold)
    (lsp-face-highlight-write   :background highlight-high :weight 'bold)
    (lsp-face-highlight-textual :background highlight-low)
    (lsp-headerline-breadcrumb-path-face        :foreground subtle)
    (lsp-headerline-breadcrumb-path-error-face  :foreground love)
    (lsp-headerline-breadcrumb-symbols-face     :foreground rose :weight 'bold)
    (lsp-ui-sideline-symbol      :foreground muted :box nil)
    (lsp-ui-sideline-current-symbol :foreground rose :weight 'bold :box nil)
    (lsp-ui-sideline-code-action :foreground gold)
    (lsp-ui-doc-background       :background surface)
    (lsp-ui-doc-header           :background surface :foreground rose :weight 'bold)
    (lsp-ui-peek-filename        :foreground rose)
    (lsp-ui-peek-header          :background overlay :foreground text :weight 'bold)
    (lsp-ui-peek-selection       :background highlight-med)
    (lsp-ui-peek-list            :background surface)
    (lsp-ui-peek-peek            :background surface)
    (lsp-ui-peek-highlight       :foreground gold :background highlight-high)
    (lsp-signature-posframe      :background surface)

    ;; --- corfu ---
    (corfu-default     :background surface :foreground text)
    (corfu-current     :background highlight-med :foreground text :weight 'bold)
    (corfu-bar         :background highlight-high)
    (corfu-border      :background overlay)
    (corfu-annotations :foreground subtle :slant 'italic)
    (corfu-deprecated  :foreground muted :strike-through t)
    (corfu-echo        :foreground subtle)
    (corfu-popupinfo   :background surface :foreground text)

    ;; --- vertico / marginalia / orderless / consult / embark ---
    (vertico-current      :background highlight-med :foreground text :extend t :weight 'bold)
    (vertico-group-title  :foreground rose :weight 'bold)
    (vertico-group-separator :foreground overlay :strike-through t)
    (vertico-multiline    :foreground muted)

    (marginalia-key       :foreground gold)
    (marginalia-mode      :foreground iris)
    (marginalia-modified  :foreground love)
    (marginalia-file-priv-dir  :foreground iris :weight 'bold)
    (marginalia-file-priv-read :foreground gold)
    (marginalia-file-priv-write :foreground love)
    (marginalia-file-priv-exec :foreground foam)
    (marginalia-file-priv-no   :foreground muted)
    (marginalia-file-name      :foreground text)
    (marginalia-file-owner     :foreground subtle)
    (marginalia-date           :foreground rose)
    (marginalia-number         :foreground numbers)
    (marginalia-size           :foreground gold)
    (marginalia-documentation  :foreground subtle :slant 'italic)
    (marginalia-type           :foreground foam)
    (marginalia-value          :foreground subtle)
    (marginalia-symbol         :foreground iris)
    (marginalia-on             :foreground foam)
    (marginalia-off            :foreground muted)

    (orderless-match-face-0 :foreground rose :weight 'bold)
    (orderless-match-face-1 :foreground gold :weight 'bold)
    (orderless-match-face-2 :foreground foam :weight 'bold)
    (orderless-match-face-3 :foreground iris :weight 'bold)

    (consult-file           :foreground text)
    (consult-bookmark       :foreground iris)
    (consult-buffer         :foreground text)
    (consult-line-number    :foreground muted)
    (consult-line-number-prefix :foreground rose)
    (consult-line-number-wrapped :foreground gold)
    (consult-narrow-indicator :foreground gold :weight 'bold)
    (consult-async-running  :foreground gold)
    (consult-async-finished :foreground foam)
    (consult-async-failed   :foreground love)
    (consult-key            :foreground gold)
    (consult-imenu-prefix   :foreground iris)
    (consult-preview-line   :background highlight-low :extend t)
    (consult-preview-match  :background gold :foreground base)
    (consult-separator      :foreground overlay :strike-through t)

    (embark-keybinding      :foreground gold :weight 'bold)
    (embark-target          :background highlight-med :foreground text :weight 'bold)
    (embark-collect-marked  :background highlight-med)
    (embark-selected        :foreground rose :weight 'bold)

    ;; --- company / ivy / helm / swiper (legacy completion) ---
    (company-tooltip                  :background surface :foreground text)
    (company-tooltip-selection        :background highlight-med :foreground text)
    (company-tooltip-annotation       :foreground subtle :slant 'italic)
    (company-tooltip-annotation-selection :foreground text :slant 'italic)
    (company-tooltip-common           :foreground rose :weight 'bold)
    (company-tooltip-common-selection :foreground rose :weight 'bold)
    (company-scrollbar-bg             :background overlay)
    (company-scrollbar-fg             :background highlight-high)
    (company-preview                  :background nil :foreground muted)
    (company-preview-common           :background nil :foreground rose)
    (company-preview-search           :background gold :foreground base)
    (company-tooltip-search           :foreground gold :weight 'bold)
    (company-tooltip-search-selection :background gold :foreground base)

    (ivy-current-match :background highlight-med :distant-foreground fg)
    (ivy-minibuffer-match-face-1 :foreground subtle :weight 'bold)
    (ivy-minibuffer-match-face-2 :foreground rose   :weight 'bold)
    (ivy-minibuffer-match-face-3 :foreground gold   :weight 'bold)
    (ivy-minibuffer-match-face-4 :foreground foam   :weight 'bold)
    (ivy-minibuffer-match-highlight :foreground iris :weight 'bold)
    (ivy-posframe :background surface)
    (ivy-virtual :foreground muted :slant 'italic)
    (ivy-confirm-face :foreground foam)
    (ivy-match-required-face :foreground love)

    (helm-selection :background highlight-med :foreground text :weight 'bold)
    (helm-source-header :background overlay :foreground rose :weight 'bold)
    (helm-match :foreground rose :weight 'bold)
    (helm-visible-mark :background gold :foreground base)
    (helm-buffer-process :foreground foam)
    (helm-buffer-directory :foreground iris)

    (swiper-line-face       :background highlight-med :extend t)
    (swiper-background-match-face-1 :inherit 'lazy-highlight)
    (swiper-match-face-1    :inherit 'ivy-minibuffer-match-face-1)
    (swiper-match-face-2    :inherit 'ivy-minibuffer-match-face-2)
    (swiper-match-face-3    :inherit 'ivy-minibuffer-match-face-3)
    (swiper-match-face-4    :inherit 'ivy-minibuffer-match-face-4)

    ;; --- doom-modeline ---
    (doom-modeline-bar                  :background rose)
    (doom-modeline-bar-inactive         :background overlay)
    (doom-modeline-buffer-path          :foreground subtle)
    (doom-modeline-buffer-file          :foreground text :weight 'bold)
    (doom-modeline-buffer-modified      :foreground gold :weight 'bold)
    (doom-modeline-buffer-major-mode    :foreground rose :weight 'bold)
    (doom-modeline-buffer-minor-mode    :foreground subtle)
    (doom-modeline-project-parent-dir   :foreground iris :weight 'bold)
    (doom-modeline-project-dir          :foreground iris :weight 'bold)
    (doom-modeline-project-root-dir     :foreground iris)
    (doom-modeline-highlight            :foreground rose)
    (doom-modeline-panel                :background rose :foreground base)
    (doom-modeline-info                 :foreground foam)
    (doom-modeline-warning              :foreground gold)
    (doom-modeline-urgent               :foreground love :weight 'bold)
    (doom-modeline-debug                :foreground subtle :slant 'italic)
    (doom-modeline-lsp-success          :foreground foam)
    (doom-modeline-lsp-warning          :foreground gold)
    (doom-modeline-lsp-error            :foreground love)
    (doom-modeline-lsp-running          :foreground iris)
    (doom-modeline-input-method         :foreground iris)
    (doom-modeline-notification         :foreground gold :weight 'bold)
    (doom-modeline-unread-number        :foreground gold :weight 'bold)
    (doom-modeline-evil-emacs-state     :foreground iris :weight 'bold)
    (doom-modeline-evil-normal-state    :foreground foam)
    (doom-modeline-evil-insert-state    :foreground gold)
    (doom-modeline-evil-visual-state    :foreground rose)
    (doom-modeline-evil-replace-state   :foreground love)
    (doom-modeline-evil-operator-state  :foreground iris)
    (doom-modeline-evil-motion-state    :foreground foam)

    ;; --- solaire ---
    (solaire-default-face       :inherit 'default :background surface)
    (solaire-hl-line-face       :background overlay)
    (solaire-mode-line-face
     :inherit 'mode-line :background modeline-bg-alt
     :box (if modeline-pad `(:line-width ,modeline-pad :color ,modeline-bg-alt)))
    (solaire-mode-line-inactive-face
     :inherit 'mode-line-inactive :background modeline-bg-inactive-alt
     :box (if modeline-pad `(:line-width ,modeline-pad :color ,modeline-bg-inactive-alt)))

    ;; --- magit ---
    (magit-section-heading           :foreground iris :weight 'bold)
    (magit-section-heading-selection :foreground rose :weight 'bold)
    (magit-section-highlight         :background highlight-low :extend t)
    (magit-section-secondary-heading :foreground iris)
    (magit-diff-file-heading         :foreground text :weight 'bold)
    (magit-diff-file-heading-highlight :background highlight-low :foreground text :weight 'bold :extend t)
    (magit-diff-hunk-heading         :foreground subtle :background overlay :extend t)
    (magit-diff-hunk-heading-highlight :foreground text :background highlight-med :extend t)
    (magit-diff-hunk-region          :weight 'bold)
    (magit-diff-context              :foreground muted :extend t)
    (magit-diff-context-highlight    :foreground subtle :background highlight-low :extend t)
    (magit-diff-added                :foreground foam :background (doom-blend foam bg 0.10) :extend t)
    (magit-diff-added-highlight      :foreground foam :background (doom-blend foam bg 0.20) :extend t)
    (magit-diff-removed              :foreground love :background (doom-blend love bg 0.10) :extend t)
    (magit-diff-removed-highlight    :foreground love :background (doom-blend love bg 0.20) :extend t)
    (magit-diff-base                 :foreground gold :background (doom-blend gold bg 0.10) :extend t)
